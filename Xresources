! vim:fdm=marker:

/* Colors {{{ */
    #include "/home/otto/documents/dotfiles/Xresources.d/colors/solarized"
/* }}} */
/* XTerm {{{ */
    /* General {{{ */
        XTerm.termName: xterm-256color
        XTerm*charClass: 33:48,36-47:48,58-59:48,61:48,63-64:48,95:48,126:48
        /* XTerm*on2Clicks: regex [[:alpha:]]+://([[:alnum:]!#+,./=?@_~-]|(%[[:xdigit:]][[:xdigit:]]))+ */
    /* }}} */
    /* Encoding {{{ */
        xterm*utf8: 2
    /* }}} */
    /* Fonts {{{ */
        XTerm.VT100.faceName: Inconsolata
        XTerm*showMissingGlyphs: true
    /* }}} */
    /* Scrolling {{{ */
        XTerm.VT100.scrollBar:       true
        XTerm.VT100.rightScrollBar:  true
        XTerm.VT100.scrollKey:       true
        XTerm.VT100.scrollLines:     1
        XTerm.VT100.scrollTtyOutput: false
        XTerm.VT100.jumpScroll:      true
        XTerm.VT100.multiScroll:     true
    /* }}} */
    /* Misc {{{ */
        /*XTerm.mainMenu.backgroundPixmap: gradient:vertical?dimension=400&start=gray10&end=gray50
         *XTerm.backgroundPixmap: xpm:/home/otto/.icons/Faenza/apps/16/terminal.xpm
         *XTerm.iconPixmap: documents/terminal1.xbm
         *XTerm.iconMask:   documents/terminal1.xbm

         *xterm*geometry:           80x25
         *xterm*dynamicColors:      true
         *xterm*utf8:               2
         *xterm*eightBitInput:      true
         *xterm*saveLines:          512
         *xterm*toolBar:            false
         */

        XTerm.VT100.translations: #override \
            <Key>F1:       string("an email address") \n\
            Ctrl<Key>Left: string(0x1b) string("b")   \n

        XTerm.VT100.Scrollbar.translations: #override \
            <Btn1Down>:   StartScroll(Continous) MoveThumb() NotifyThumb() \n\
            <Btn1Motion>: MoveThumb() NotifyThumb()                        \n\
            <Btn2Down>:   StartScroll(Continous) MoveThumb() NotifyThumb() \n\
            <Btn2Motion>: MoveThumb() NotifyThumb()                        \n\
            <Btn3Down>:   StartScroll(Continous) MoveThumb() NotifyThumb() \n\
            <Btn3Motion>: MoveThumb() NotifyThumb()                        \n\
            <BtnUp>:      NotifyScroll(Proportional) EndScroll()           \n
    /* }}} */
/* }}} */
